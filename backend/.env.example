# Database Configuration
DB_USER=postgres
DB_HOST=localhost
DB_NAME=security_onboarding
DB_PASSWORD=your_password_here
DB_PORT=5432

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=5001
FRONTEND_URL=http://localhost:3000

# ts_man database (same GCP Cloud SQL host, separate database)
# In production DB_HOST is the Cloud SQL socket — TSMAN_DB_HOST is ignored and DB_HOST is reused
TSMAN_DB_HOST=<cloud-sql-ip>
TSMAN_DB_NAME=tsmandb
TSMAN_DB_USER=postgres
TSMAN_DB_PASSWORD=your_tsman_password_here

# ExchangeRate-API (https://www.exchangerate-api.com/)
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here
